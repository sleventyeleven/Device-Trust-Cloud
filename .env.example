# Device Trust Configuration
# Copy this file to .env and update with your values

# SCEP Server Configuration
SCEP_SERVER_URL=https://step-ca.example.com
SCEP_PROVISIONER=poc_devicetrust
SCEP_CHALLENGE=your-secret-challenge-here

# Certificate Subject Configuration
CERT_COUNTRY=US
CERT_ORGANIZATION=DeviceTrust
CERT_OU=Device Trust

# Root CA Certificate URL (optional)
ROOT_CA_URL=https://step-ca.example.com/root-ca.crt